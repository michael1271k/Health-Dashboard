<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  HealthKit FOREGROUND read access. A FREE personal Apple team CAN provision
	  `com.apple.developer.healthkit` (foreground) — it just cannot provision
	  `com.apple.developer.healthkit.background-delivery`, which is why that one
	  stays OUT (its presence crashed the app at launch on a free team).
	  Sync therefore runs on app-open + pull-to-refresh only; no silent
	  background delivery until on the paid program (then re-add background-delivery).
	-->
	<key>com.apple.developer.healthkit</key>
	<true/>
	<!--
	  Associated Domains → iOS Password AutoFill. `webcredentials:` links this app
	  to the Netlify domain the WKWebView loads, so on first manual sign-in iOS
	  offers "Save Password?" to the iCloud Keychain and AutoFills it on a fresh
	  install. Requires the matching apple-app-site-association webcredentials file
	  (public/.well-known/, served as application/json via netlify.toml) AND the
	  Associated Domains capability enabled on the Xcode target.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>webcredentials:helix-health-fitness.netlify.app</string>
	</array>
</dict>
</plist>
